VITE_APP_NAME="Pelek Properties"

# Lightweight API compatibility (mirror DB_* for the api/ scripts)
MYSQL_HOST="127.0.0.1"
MYSQL_PORT="3306"
MYSQL_DATABASE="cpaneluser_pelek"
